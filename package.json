{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --go --host tunnel",
    "start:clear": "expo start --go --host tunnel --clear",
    "start:lan": "expo start --go --host lan",
    "start:dev-client": "expo start --dev-client --host tunnel",
    "start:dev-client:lan": "expo start --dev-client --host lan",
    "start:tunnel": "expo start --go --host tunnel",
    "android": "expo start --android --go --host tunnel",
    "android:lan": "expo start --android --go --host lan",
    "android:dev-client": "expo start --android --dev-client --host tunnel",
    "android:dev-client:lan": "expo start --android --dev-client --host lan",
    "android:native": "expo run:android",
    "ios": "expo run:ios",
    "test": "tsc -p tsconfig.spec.json && node .tmp-tests/lib/auth-session-client.spec.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build": "expo export"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^3.10.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.68.0",
    "axios": "^1.8.4",
    "debug": "^4.3.4",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "metro-runtime": "0.83.5",
    "nativewind": "4.1.23",
    "react": "19.1.0",
    "react-hook-form": "^7.54.2",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-css-interop": "0.1.22",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.13.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
